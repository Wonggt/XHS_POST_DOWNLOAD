# Platform cookies (optional) — paste each platform's Cookie header value
# from a logged-in session to unlock private/gated posts.
XHS_COOKIE=
IG_COOKIE=
TIKTOK_COOKIE=
FB_COOKIE=

# Feedback email (Resend — https://resend.com)
# 1. Sign up (free), get an API key at resend.com/api-keys
# 2. Set the three vars below and restart the server
RESEND_API_KEY=
FEEDBACK_TO_EMAIL=
FEEDBACK_FROM_EMAIL=
